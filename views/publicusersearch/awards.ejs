<!DOCTYPE html>
<html lang="en" class="govuk-template">
<head>
  <title>GOV.UK - Public user awards result page</title>

  <%- include('../partials/headercss.ejs') %>

  <link href="/assets/stylesheet/style.css" rel="stylesheet" type="text/css">  
</head>

<body class="govuk-template__body app-example-page">
  <script>
    document.body.className = document.body.className
      ? document.body.className + ' js-enabled'
      : 'js-enabled';
  </script>

  <%- include('../partials/cookies-consent.ejs') %>
  <%- include('../partials/header.ejs') %>

  <div class="govuk-width-container">
    <%- include('../partials/banner.ejs') %>

    <main id="main-content" role="main">
      <div class="govuk-main-wrapper">
        <% const awards = results.awards || []; %>
        <% const totalSearchResults = results.totalSearchResults || 0; %>

        <div class="govuk-grid-row">
          <div class="govuk-grid-column-two-thirds">
            <h1 class="govuk-heading-l">Find subsidy awards</h1>
          </div>
          <div class="govuk-grid-column-one-third">
            <a href="/" class="govuk-button pull-right">
              New search
            </a>
          </div>
        </div>
        <div class="govuk-grid-row">
          <div class="govuk-grid-column-full">
            <p class="govuk-body">
              <strong id="number-of-results"><%= totalSearchResults %></strong>
              <%= totalSearchResults === 1 ? 'subsidy award found' : 'subsidy awards found' %>
            </p>
          </div>
        </div>
        <div class="govuk-grid-row">
          <div class="govuk-grid-column-full">
            <%
            function exportUrl(format) {
              const params = new URLSearchParams();
          
              params.set('format', format);
          
              Object.keys(filters || {}).forEach(function(key) {
                if (filters[key]) {
                  params.set(key, filters[key]);
                }
              });
          
              return '/awards/export?' + params.toString();
            }
            %>
            <p class="govuk-body">
              <a class="govuk-link" href="<%= exportUrl('xlsx') %>">
                Export as Excel file
              </a>
            &nbsp;
              <a class="govuk-link" href="<%= exportUrl('csv') %>">
                Export as CSV file
              </a>
            </p>
          </div>
        </div>

        <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">

        <div class="govuk-grid-row">
            <div class="govuk-grid-column-one-third">
              <div class="filters-container">
                <div class="filters-header">
                  <p class="govuk-body govuk-!-margin-bottom-0">Filter by</p>
                  <!-- Need to have an onclick() event for this which clears and resets all of the filters -->
                  <a href="#" class="govuk-link">Clear all</a> 
                </div>

                <br/>
                <!-- Filters go here -->
                <form id="filter-form" action="/awards" method="GET">
                  <!-- Hidden input fields to preserve page, size, and sorting -->
                  <input type="hidden" name="page" value="1">
                  <input type="hidden" name="size" value="<%= size %>">
                  <input type="hidden" name="sort" value="<%= filters.sort || 'publishedDate,desc' %>">
                  <button class="govuk-button">Update results</button>
                </form>
              </div>
            </div>

          <div class="govuk-grid-column-two-thirds">
            <!-- Sort Start -->
            <form action="/awards" method="GET" class="govuk-form-group">
              <label class="govuk-label" for="sort">
                Sort by
              </label>
            
              <select class="govuk-select" id="sort" name="sort">
                <option value="publishedDate,desc" <%= filters.sort === 'publishedDate,desc' ? 'selected' : '' %>>
                  Published date, newest first
                </option>
            
                <option value="publishedDate,asc" <%= filters.sort === 'publishedDate,asc' ? 'selected' : '' %>>
                  Published date, oldest first
                </option>
            
                <option value="recipientName,asc" <%= filters.sort === 'recipientName,asc' ? 'selected' : '' %>>
                  Recipient name, A to Z
                </option>
            
                <option value="recipientName,desc" <%= filters.sort === 'recipientName,desc' ? 'selected' : '' %>>
                  Recipient name, Z to A
                </option>
              </select>
            
              <input type="hidden" name="page" value="1">
              <input type="hidden" name="size" value="<%= size %>">
            
              <% Object.keys(filters || {}).forEach(function(key) { %>
                <% if (key !== 'sort' && filters[key]) { %>
                  <input type="hidden" name="<%= key %>" value="<%= filters[key] %>">
                <% } %>
              <% }); %>
            
              <button class="govuk-button govuk-!-margin-left-2" type="submit">
                Apply sort
              </button>
            </form>
            <!-- Sort End -->
            <% if (awards.length === 0) { %>
              <p class="govuk-body">No subsidy awards match your search.</p>
            <% } else { %>
              <% awards.forEach(function(item, index) { %>
                <% const description = item.subsidyAwardDescription || ''; %>
                <% const shortDescription = description.length > 130 ? description.substring(0, 130) + '...' : description; %>

                <article class="govuk-!-margin-bottom-4">
                  <a class="govuk-link govuk-heading-m" href="/searchresultsawardroute/?page=<%= item.awardNumber %>">
                    <%= item.beneficiary && item.beneficiary.beneficiaryName ? item.beneficiary.beneficiaryName : 'Unnamed award' %>
                  </a>

                  <% if (shortDescription) { %>
                    <p class="govuk-body"><%= shortDescription %></p>
                  <% } %>

                  <dl class="govuk-summary-list govuk-summary-list--no-border">
                    <div class="govuk-summary-list__row">
                      <dt class="govuk-summary-list__key">Recipient name</dt>
                      <dd class="govuk-summary-list__value">
                        <%= item.beneficiary && item.beneficiary.beneficiaryName ? item.beneficiary.beneficiaryName : 'N/A' %>
                      </dd>
                    </div>

                    <div class="govuk-summary-list__row">
                      <dt class="govuk-summary-list__key">Subsidy amount</dt>
                      <dd class="govuk-summary-list__value">
                        <% if (item.subsidyInstrument === "Tax measures (tax credit, or tax/duty exemption)") { %>
                          <%= item.subsidyFullAmountRange || 'N/A' %>
                        <% } else { %>
                          <%= item.subsidyFullAmountExact ? '£' + item.subsidyFullAmountExact : 'N/A' %>
                        <% } %>
                      </dd>
                    </div>

                    <div class="govuk-summary-list__row">
                      <dt class="govuk-summary-list__key">Public authority</dt>
                      <dd class="govuk-summary-list__value">
                        <%= item.grantingAuthorityResponse && item.grantingAuthorityResponse.grantingAuthorityName
                          ? item.grantingAuthorityResponse.grantingAuthorityName
                          : 'N/A' %>
                      </dd>
                    </div>

                    <div class="govuk-summary-list__row">
                      <dt class="govuk-summary-list__key">Subsidy scheme</dt>
                      <dd class="govuk-summary-list__value">
                        <% if (item.standaloneAward === "Yes") { %>
                          N/A
                        <% } else { %>
                          <%= item.subsidyMeasure && item.subsidyMeasure.subsidyMeasureTitle
                            ? item.subsidyMeasure.subsidyMeasureTitle
                            : 'N/A' %>
                        <% } %>
                      </dd>
                    </div>

                    <div class="govuk-summary-list__row">
                      <dt class="govuk-summary-list__key">Subsidy form</dt>
                      <dd class="govuk-summary-list__value">
                        <%= item.subsidyInstrument || 'N/A' %>
                      </dd>
                    </div>

                    <div class="govuk-summary-list__row">
                      <dt class="govuk-summary-list__key">Sector</dt>
                      <dd class="govuk-summary-list__value">
                        <%= item.spendingSector || 'N/A' %>
                      </dd>
                    </div>

                    <div class="govuk-summary-list__row">
                      <dt class="govuk-summary-list__key">Date published</dt>
                      <dd class="govuk-summary-list__value">
                        <%= item.publishedAwardDate || 'N/A' %>
                      </dd>
                    </div>
                  </dl>
                </article>

                <% if (index < awards.length - 1) { %>
                  <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">
                <% } %>
              <% }); %>
            <% } %>
          </div>
          <!-- Start of Pagination -->
          <% if (pageCount > 1) { %>
            <%
              const currentPage = Number(page || 1);
              const totalPages = Number(pageCount || 1);
          
              function pageUrl(pageNumber) {
                const params = new URLSearchParams();
          
                params.set('page', pageNumber);
                params.set('size', size);
          
                Object.keys(filters || {}).forEach(function(key) {
                  if (filters[key]) {
                    params.set(key, filters[key]);
                  }
                });
          
                return '/awards?' + params.toString();
              }
          
              let pages = [];
          
              if (totalPages <= 7) {
                for (let i = 1; i <= totalPages; i++) {
                  pages.push(i);
                }
              } else {
                pages.push(1);
          
                if (currentPage > 4) {
                  pages.push('ellipsis-start');
                }
          
                let startPage = Math.max(2, currentPage - 1);
                let endPage = Math.min(totalPages - 1, currentPage + 1);
          
                if (currentPage <= 4) {
                  startPage = 2;
                  endPage = 5;
                }
          
                if (currentPage >= totalPages - 3) {
                  startPage = totalPages - 4;
                  endPage = totalPages - 1;
                }
          
                for (let i = startPage; i <= endPage; i++) {
                  pages.push(i);
                }
          
                if (currentPage < totalPages - 3) {
                  pages.push('ellipsis-end');
                }
          
                pages.push(totalPages);
              }
            %>

            <div id="pagination1" class="pagination govuk-grid-row">
              
              <% if (pageCount > 1) { %>
                <div class="govuk-grid-column-one-third first">
                  <p class="pagination-label">
                    Showing <span><%= startRecord %></span> - <span><%= endRecord %></span> of
                    <span><%= totalSearchResults %></span> records
                  </p>
                </div>
              <% } %>

              <div class="govuk-grid-column-two-thirds last govuk-padding-0 govuk-display-flex">

                <% if (currentPage > 1) { %>
                  <a href="<%= pageUrl(currentPage - 1) %>" id="paginationlink_previous_page" class="previous round" rel="prev">
                    <svg class="govuk-pagination__icon govuk-pagination__icon--prev"
                         xmlns="http://www.w3.org/2000/svg"
                         height="13"
                         width="15"
                         aria-hidden="true"
                         focusable="false"
                         viewBox="0 0 15 13">
                      <path d="m6.5938-0.0078125-6.7266 6.7266 6.7441 6.4062 1.377-1.449-4.1856-3.9768h12.896v-2h-12.984l4.2931-4.293-1.414-1.414z"></path>
                    </svg>
                    Previous<span class="govuk-visually-hidden"> page</span>
                  </a>
                <% } %>

                <% pages.forEach(function(pageItem) { %>
                  <% if (pageItem === 'ellipsis-start' || pageItem === 'ellipsis-end') { %>
                    <span class="round btn-page pagination-ellipsis">
                      &ctdot;
                    </span>
                  <% } else if (pageItem === currentPage) { %>
                    <a id="paginationlink<%= pageItem %>" aria-label="go to page <%= pageItem %>" class="round btn-page active" href="<%= pageUrl(pageItem) %>" aria-current="page">
                      <%= pageItem %>
                    </a>
                  <% } else { %>
                    <a id="paginationlink<%= pageItem %>" aria-label="go to page <%= pageItem %>" class="round btn-page" href="<%= pageUrl(pageItem) %>">
                      <%= pageItem %>
                    </a>
                  <% } %>
                <% }); %>

                <% if (currentPage < totalPages) { %>
                  <a href="<%= pageUrl(currentPage + 1) %>" id="paginationlink_next_page" aria-label="go to next page" class="next round" rel="next">
                    Next<span class="govuk-visually-hidden"> page</span>
                    <svg class="govuk-pagination__icon govuk-pagination__icon--next"
                         xmlns="http://www.w3.org/2000/svg"
                         height="13"
                         width="15"
                         aria-hidden="true"
                         focusable="false"
                         viewBox="0 0 15 13">
                      <path d="m8.107-0.0078125-1.4136 1.414 4.2926 4.293h-12.986v2h12.896l-4.1855 3.9766 1.377 1.4492 6.7441-6.4062-6.7246-6.7266z"></path>
                    </svg>
                  </a>
                <% } %>
              </div>
            </div>
          <% } %>
          <!-- End of Pagination -->
        </div>
      </div>
    </main>
  </div>

  <%- include('../partials/footer.ejs') %>
</body>
</html>